{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/i18n.config.ts",
    "app/server/api/**/*.{js,ts}",
    "app/server/routes/**/*.{js,ts}",
    "vitest.config.ts",
    "vitest.happy-dom.config.ts",
    "vitest.nuxt.config.ts",
    "vitest.shared.ts"
  ],
  "ignore": [
    "supabase/functions/**",
    "app/components/PromotedTwitchEmbed.vue",
    "app/i18n.config.ts",
    "app/server/api/changelog.get.ts",
    "app/server/api/contributors.get.ts",
    "vitest.happy-dom.config.ts",
    "vitest.nuxt.config.ts",
    "vitest.shared.ts"
  ],
  "ignoreDependencies": [
    "@iconify-json/mdi",
    "@semantic-release/npm",
    "@tailwindcss/postcss",
    "autoprefixer",
    "defu",
    "lru-cache",
    "postcss",
    "vitest-environment-nuxt",
    "vue-tsc",
    "@nuxt/kit"
  ],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    "workers/api-gateway": {
      "entry": [
        "scripts/validate-openapi.ts",
        "src/**/__tests__/**/*.test.ts",
        "src/index.ts",
        "vitest.config.ts"
      ],
      "project": ["scripts/**/*.ts", "src/**/*.ts", "vitest.config.ts"]
    }
  }
}
